# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MoA Gateway Pro - PostgreSQL Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your values:
#   cp postgres.env.example .env

# ── Database Connection ──
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg2://moa_user:change_me_strong_password@localhost:5432/moa_gateway

# ── Connection Pool (production-grade defaults) ──
DB_POOL_SIZE=20          # Core connections maintained
DB_MAX_OVERFLOW=10       # Burst overflow (total max = pool_size + max_overflow = 30)
DB_POOL_TIMEOUT=30       # Seconds to wait for available connection
DB_POOL_RECYCLE=3600     # Recycle connections every hour (prevents stale connections)
DB_POOL_PRE_PING=true    # Health-check before borrowing connection

# ── Debug (set to true for SQL query logging) ──
DB_ECHO=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL Server Setup (if needed)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. Create database and user:
#    CREATE USER moa_user WITH PASSWORD 'change_me_strong_password';
#    CREATE DATABASE moa_gateway OWNER moa_user;
#    GRANT ALL PRIVILEGES ON DATABASE moa_gateway TO moa_user;
#
# 2. Run migrations:
#    alembic upgrade head
#
# 3. Start the server:
#    python -m moa_gateway.server
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
